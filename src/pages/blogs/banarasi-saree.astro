---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ImagePair from "../../components/ImagePair.astro";
import post from "../../content/banarasi-saree.json";
---
<BlogPostLayout
  title={post.title}
  subtitle={post.subtitle}
  meta={post.meta}
  hero={post.hero}
  numeral="II"
  kicker="Craft · Lallapura"
  location="Lallapura, Varanasi"
  date="June 2025"
  readTime="10 min"
  coords="25.3347° N, 82.9734° E"
  nextSlug="sarnath"
  nextNumeral="III"
  nextTitle="Sarnath"
  nextSubtitle="Where the Wheel of Dharma was Turned"
  nextHero="/images/blog/sarnath/hero.jpg"
>
  {post.blocks.map((block) =>
    block.type === "h" ? (
      <h2 class="font-display text-2xl sm:text-3xl text-ink mt-12 mb-4 leading-snug">{block.text}</h2>
    ) : block.type === "p" ? (
      <p class="font-body text-xl text-ink/90 leading-relaxed mb-6">{block.text}</p>
    ) : (
      <ImagePair images={block.images} caption={block.caption} />
    )
  )}
</BlogPostLayout>
