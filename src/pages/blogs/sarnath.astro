---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import ImagePair from "../../components/ImagePair.astro";
import post from "../../content/sarnath.json";
---
<BlogPostLayout
  title={post.title}
  subtitle={post.subtitle}
  meta={post.meta}
  hero={post.hero}
  numeral="III"
  kicker="Pilgrimage · 8 km from Banaras"
  location="Sarnath, Uttar Pradesh"
  date="July 2025"
  readTime="12 min"
  coords="25.3810° N, 83.0225° E"
  nextSlug="varanasi-food"
  nextNumeral="IV"
  nextTitle="Best Foods in Varanasi"
  nextSubtitle="Your Guide to Iconic Local Flavors"
  nextHero="/images/blog/varanasi-food/hero.png"
>
  {post.blocks.map((block) =>
    block.type === "h" ? (
      <h2 class="font-display text-2xl sm:text-3xl text-ink mt-12 mb-4 leading-snug">{block.text}</h2>
    ) : block.type === "p" ? (
      <p class="font-body text-xl text-ink/90 leading-relaxed mb-6">{block.text}</p>
    ) : (
      <ImagePair images={block.images} caption={block.caption} />
    )
  )}
</BlogPostLayout>
