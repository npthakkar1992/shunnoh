---
import BaseLayout from "../layouts/BaseLayout.astro";

const categories = [
  {
    id: "experiential",
    number: "01",
    labelShort: "Experiential Travel",
    titleLead: "Experiential Travel & ",
    titleEm: "Immersive",
    titleTail: " Writing",
    line: "Writing that puts the reader inside the moment — every sense engaged.",
    cardImage: "/images/blog/goa/hero.png",
    bgAlt: false,
    articles: [
      {
        title: "Goa's Glowing Forest",
        city: "Goa, India",
        pub: "Shunnoh",
        href: "/blogs/goa",
        image: "/images/blog/goa/card.png",
        imageAlt: "Goa's bioluminescent monsoon forest",
        preview: "Beyond its vibrant beaches, bustling casinos, and lively parties, Goa also has a lesser-known yet equally captivating side.",
      },
      {
        title: "Ruskin Bond",
        city: "Landour, India",
        pub: "Coming Soon",
        href: "/pdfs/ruskin-bond.pdf",
        image: null,
        imageAlt: "Ruskin Bond's Landour",
        preview: "Tang, tang, tang, tang, tang, and it was five in the morning. The sound came through exactly the way he had written it.",
      },
      {
        title: "Trek",
        city: "India",
        pub: "Coming Soon",
        href: "/pdfs/trek.pdf",
        image: null,
        imageAlt: "A high-altitude trek",
        preview: "As I looked at the sky, language became briefly inadequate. I had seen stars before, but I had not seen the sky before.",
      },
    ],
    bento: [
      { src: "/images/blog/goa/01.jpg", alt: "Goa's monsoon forest" },
      { src: "/images/blog/varanasi/ganga-aarti.jpg", alt: "Ganga Aarti at Dashashwamedh Ghat" },
      { src: "/images/blog/goa/09.jpg", alt: "Inside the forest canopy" },
      { src: "/images/blog/varanasi/evening-ghats.jpg", alt: "Evening on the ghats" },
      { src: "/images/blog/goa/12.jpg", alt: "Monsoon greens in Mollem" },
    ],
    excerpts: [
      "As I looked at the sky, language became briefly inadequate. I had seen stars before, but I had not seen the sky before. Not like this.",
      "As dusk paints the Varanasi sky in hues of orange and purple, Dashashwamedh Ghat transforms into a stage for the mesmerizing Ganga Aarti. The air buzzes with anticipation as priests, clad in vibrant silk robes, prepare for the ceremony.",
      "Stepping off the plane, I noticed a fellow passenger pause. The moment his foot touched the ground, he set his luggage aside and, with a reverent bow, touched his forehead to the cold tarmac — a silent, heartfelt greeting to the sacred city of ghats, Varanasi.",
      "With all our torches off, deep in the jungle, we found ourselves mesmerized by these enigmatic organisms. Even the moonlight felt intrusive.",
      "In the distance, cattle grazed on vibrant green slopes, their bells harmonizing with the birdsong. The sky was a soft pale blue, and the sun shy behind thin clouds. It made me re-believe my childhood sketches, which I once thought only existed in drawing books.",
      "Tang, tang, tang, tang, tang, and it was five in the morning. Snuggled under a blanket, warmed by the heater, the sound came through exactly the way he had written it. Not described. Not paraphrased. Exactly. The clock tower was not a landmark I had to find on a map. It found me, lying in bed, half asleep, in a town I was only beginning to understand.",
    ],
  },
  {
    id: "destinations",
    number: "02",
    labelShort: "Destination Stories",
    titleLead: "Destination Stories and the ",
    titleEm: "Murmur",
    titleTail: " of History",
    line: "Places told through their people, their rituals, and the history beneath them.",
    cardImage: "/images/blog/sarnath/hero.jpg",
    bgAlt: true,
    articles: [
      {
        title: "Hoi An",
        city: "Hoi An, Vietnam",
        pub: "Coming Soon",
        href: null,
        image: null,
        imageAlt: "The old town of Hoi An",
        preview: "The town wasn't preserved because it was loved. It was preserved because it was forgotten. The love came afterwards.",
      },
      {
        title: "Sarnath — Where the Wheel of Dharma was Turned",
        city: "Sarnath, India",
        pub: "Shunnoh",
        href: "/blogs/sarnath",
        image: "/images/blog/sarnath/card.png",
        imageAlt: "Sarnath, the cradle of Buddhism",
        preview: "Travelling just 8 kilometers from Varanasi will help you unfold a different side of spirituality.",
      },
      {
        title: "Varanasi — Here, you either find Him, or you lose faith in Him",
        city: "Varanasi, India",
        pub: "Shunnoh",
        href: "/blogs/varanasi",
        image: "/images/blog/varanasi/hero.jpg",
        imageAlt: "The ghats of Varanasi",
        preview: "Banaras, ghato ka shehar ya shiv ki nagri? A city etched in time; its stories whispered through ancient scriptures.",
      },
    ],
    bento: [
      { src: "/images/blog/varanasi/shores-1.jpg", alt: "The shores of the Ganges" },
      { src: "/images/blog/sarnath/01.png", alt: "The stupa at Sarnath" },
      { src: "/images/blog/varanasi/lanes-1.jpg", alt: "The lanes of Varanasi" },
      { src: "/images/blog/sarnath/07.png", alt: "Monastic ruins at Sarnath" },
      { src: "/images/blog/varanasi/boat-1.jpg", alt: "A boat on the Ganges" },
    ],
    excerpts: [
      "The town wasn't preserved because it was loved. It was preserved because it was forgotten. The love came afterwards.",
      "These were the giếng trời, the sky wells, a layout born out of a tax hack. When the property tax was based on street frontage, merchants built narrow but long tube houses, with a courtyard punched through the middle to let the sky in. Centuries-old tax avoidance is now considered beautiful traditional architecture.",
      "A few kilometers from Varanasi, temple bells get replaced with bonshōs and damrus with prayer wheels. Temples take shapes of monasteries and purohits get replaced by monks. This is Sarnath.",
      "On the same bank of the Ganges, the glorious Ganga Aarti illuminates one side, while blazing funeral pyres flicker on the other. Here, generosity and exploitation coexist. This is a city of striking polarity, embracing the divine radiance and the darkness of death in the same breath.",
      "According to Vietnamese and Japanese folklore, Namazu is a giant catfish whose movements cause earthquakes and floods across Asia. And it sits right below this bridge. The Japanese merchants who settled here believed they were standing on its spine. So they built the bridge to pin the creature down, and stop earthquakes in Japan and floods in Hoi An.",
      "Over the years they compiled The Landour Cookbook, a collection of tried and tested recipes with cooking methods adjusted for 7,000 feet. When you order today, you are eating recipes attributed to actual women from a century ago: Mary Hoke's chocolate chip date cake, Mrs. Russel's coffee streusel cake, Vesta Miller's mud pie.",
    ],
  },
  {
    id: "craft",
    number: "03",
    labelShort: "Craft & Culture",
    titleLead: "Craft & Culture — The ",
    titleEm: "Making",
    titleTail: " of Things",
    line: "The artisans, the looms, and the hands that shape heritage.",
    cardImage: "/images/blog/banarasi-saree/hero.png",
    bgAlt: false,
    articles: [
      {
        title: "The Banarasi Saree — From the Gods, through the Royals, to the Masses",
        city: "Varanasi, India",
        pub: "Shunnoh",
        href: "/blogs/banarasi-saree",
        image: "/images/blog/banarasi-saree/hero.png",
        imageAlt: "Banarasi saree weaving",
        preview: "Banarasi saree, a bridal echo, a royal legacy; a testament to timeless elegance that has been defining affluence through eras.",
      },
      {
        title: "Poila Baisakh",
        city: "Bengal, India",
        pub: "Coming Soon",
        href: null,
        image: null,
        imageAlt: "Poila Baisakh, the Bengali new year",
        preview: "What started as a tax reform in 1556 is today a feast, a reason for families to gather at the turn of the Bengali new year.",
      },
      {
        title: "Hoi An",
        city: "Hoi An, Vietnam",
        pub: "Coming Soon",
        href: null,
        image: null,
        imageAlt: "Craft stories from Hoi An",
        preview: "Cao lầu, a noodle that is a prisoner of this town's geography. Not because of its recipe but because of its key ingredients.",
      },
    ],
    bento: [
      { src: "/images/blog/banarasi-saree/01.png", alt: "A Banarasi loom at work" },
      { src: "/images/blog/banarasi-saree/04.png", alt: "Silk threads on the loom" },
      { src: "/images/blog/banarasi-saree/07.png", alt: "A weaver's hands" },
      { src: "/images/blog/banarasi-saree/10.png", alt: "Naksha patta punch cards" },
      { src: "/images/blog/banarasi-saree/14.png", alt: "The finished Banarasi saree" },
    ],
    excerpts: [
      "The rhythmic clatter of looms whispers of the artistry of Banarasi saree weaving. The lanes, awash with murky dye water flowing from countless small workshops, make it hard to guess the brilliance of the finished sarees from the dark, discarded water staining the way.",
      "Cao lầu, a noodle that is a prisoner of this town's geography. Not because of its recipe but because of its key ingredients: water from a 10th-century well and lye ash from a certain type of tree from a specific island. The name is a fossil. Cao means high. Lầu means floor. Once served on the upper floors of riverfront merchant houses to wealthy traders. Now, a street food.",
      "The Naksha Pattas are the sole codes that these jacquard looms understand, much like binary codes are for computers.",
      "What started as a tax reform in 1556 is today a feast, a reason for families to gather, to wear new clothes and still open fresh ledgers at the turn of the Bengali new year, long after they left the fields behind.",
      "A Muslim community, where skilled weavers, mostly men wearing skullcaps, produced the iconic Banarasi sarees, a staple for Hindu weddings. The interweaving of cultures, evident in the workshop, hinted at a deeper, more complex history.",
    ],
  },
];

// focal: top | center | bottom | left | right | custom "50% 25%" — maps to object-position
const focalMap = { top: "center top", center: "center", bottom: "center bottom", left: "left center", right: "right center" };
const objectPosition = (f) => focalMap[f ?? "center"] ?? f;

const skills = [
  "Consumer Research (Nielsen)", "Search Strategy & SEO", "Editorial Writing",
  "Travel Photography", "Cultural & Historical Research", "Hindi · Bengali · English",
];
---
<BaseLayout title="For Editors — Shunnoh" description="Barnali's editorial portfolio — immersive travel writing, cultural features, and destination storytelling for publications." noindex={true}>
  <div class="editor-page paper-texture">
    <!-- Sticky category label (reader orientation cue) -->
    <div class="category-sticky-label" aria-hidden="true"></div>

    <!-- NAV (frosted) -->
    <nav class="ed-nav">
      <a href="/" class="ed-nav-logo" aria-label="Shunnoh — home"><img src="/images/branding/logo-wordmark-dark.svg" alt="Shunnoh" class="ed-nav-logo-img" width="210" height="48" /></a>
      <ul class="ed-nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blogs">Blog</a></li>
        <li><a href="#contact">Get in Touch</a></li>
      </ul>
    </nav>

    <!-- HERO -->
    <section class="editor-hero">
      <div class="editor-hero-badge ed-load ed-load-badge">For Editors &amp; Publications</div>
      <h1 class="ed-load ed-load-h1">I don't write about destinations, I make you <em>live</em> through them.</h1>
      <p class="editor-hero-tagline ed-load ed-load-tagline">A writer who breathes life into your stories</p>
      <p class="editor-hero-intro ed-load ed-load-intro1">I'm Barnali, the writer behind Shunnoh. I specialise in immersive, research-rich travel features — the kind where a reader doesn't just learn about a place, they feel like they've been there. If your publication values depth, sensory detail, and cultural authenticity, we should talk.</p>
    </section>

    <!-- STYLES OF WRITING (category card navigator) -->
    <section class="styles-section" id="styles-of-writing">
      <div class="styles-header reveal">
        <h2 class="section-heading">Styles of Writing</h2>
        <p class="styles-desc"><em>Three ways I approach a place.</em></p>
      </div>
      <div class="styles-grid">
        {categories.map((c) => (
          <a href={`#${c.id}`} class="style-card reveal" data-category={c.id}>
            <span class="style-card-number">{c.number}</span>
            <span class="style-card-title">{c.titleLead}{c.titleEm}{c.titleTail}</span>
            <span class="style-card-line">{c.line}</span>
            <span class="style-card-img">
              <img src={c.cardImage} alt="" loading="lazy" aria-hidden="true" />
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- CATEGORY SECTIONS -->
    {categories.map((c) => (
      <section class={`category-section ${c.bgAlt ? "bg-alt" : ""}`} id={c.id} data-category-section={c.id} data-category-label={`${c.number} — ${c.labelShort}`} data-bg={c.bgAlt ? "parchment" : "warm-white"}>
        <div class="category-header">
          <div class="category-number">{c.number}</div>
          <h2 class="category-title">{c.titleLead}<em>{c.titleEm}</em>{c.titleTail}</h2>
          <p class="category-line">{c.line}</p>
        </div>

        <div class="article-grid">
          {c.articles.map((a) => {
            const inner = (
              <>
                <span class="article-card-imgwrap">
                  {a.image ? (
                    <img src={a.image} alt={a.imageAlt} loading="lazy" class="article-card-img" />
                  ) : (
                    <span class="article-card-img article-card-placeholder" aria-hidden="true"></span>
                  )}
                </span>
                <span class="article-card-body">
                  <span class="article-card-title">{a.title}</span>
                  <span class="article-card-city">{a.city}</span>
                  <span class="article-card-pub">{a.pub}</span>
                  <span class="article-card-preview">{a.preview}</span>
                </span>
              </>
            );
            return a.href ? (
              <a href={a.href} class="article-card reveal">{inner}</a>
            ) : (
              <div class="article-card article-card-soon reveal">{inner}</div>
            );
          })}
        </div>

        <div class="bento-grid">
          {c.bento.map((img, i) => (
            <div class={`bento-cell bento-cell-${i + 1}`}>
              <img src={img.src} alt={img.alt} loading="lazy" style={`object-position:${objectPosition(img.focal)};`} />
            </div>
          ))}
        </div>

        <div class="category-excerpts">
          {c.excerpts.map((ex) => (
            <div class="theme-excerpt reveal">
              <blockquote>{ex}</blockquote>
            </div>
          ))}
        </div>
      </section>
    ))}

    <!-- ABOUT BARNALI -->
    <section class="about-barnali">
      <div class="about-layout">
        <div class="about-photo reveal">Barnali — portrait</div>
        <div class="about-text reveal reveal-delay-1">
          <div class="section-label">About the Writer</div>
          <h2>Research runs deep. The writing makes it <em>sing.</em></h2>
          <p>Before Shunnoh, I spent years at Nielsen — working across research, consumer insights, and data strategy. That training didn't disappear when I picked up a notebook. It shaped the writer I became.</p>
          <p>Every Shunnoh piece begins with deep, structured research — historical records, conversations with artisans, local archives, cultural context most writers skip. The difference between a travel blog and a Shunnoh feature is that the homework is done before the first sentence is written. The loom techniques in the Banarasi Saree piece, the mythology behind Manikarnika — none of that is surface-level Googling. It's fieldwork.</p>
          <p>But research alone doesn't make someone read to the end. What I bring is the ability to take that depth and weave it into narrative — sensory, immersive, human. The reader gets the rigour without feeling the weight. They get a story that's meticulously accurate and genuinely enjoyable to read.</p>
          <p>That combination — the researcher's discipline and the writer's instinct — is what I offer your publication.</p>
          <div class="about-skills">
            {skills.map((s) => <span class="about-skill-tag">{s}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="editor-contact" id="contact">
      <h2 class="reveal">Interested in <em>working together?</em></h2>
      <p class="editor-contact-sub reveal reveal-delay-1">I'm open to commissions, contributor roles, and editorial collaborations. Happy to discuss rates, adapt to your house style, or send full drafts of any unpublished piece.</p>
      <a href="mailto:hello@shunnoh.com" class="editor-contact-email reveal reveal-delay-2">hello@shunnoh.com</a>
      <div class="editor-contact-links reveal reveal-delay-2">
        <a href="https://www.instagram.com/shunnoh_" target="_blank" rel="noopener noreferrer">Instagram</a>
      </div>
      <div class="editor-cta-explore reveal reveal-delay-3">
        <a href="/">Explore Shunnoh
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="ed-footer">
      <p>&copy; 2026 Shunnoh. All rights reserved.</p>
      <p>This page is shared privately with editors and publications.</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .editor-page {
    --ink: #1a1714;
    --parchment: #f5f0e8;
    --warm-white: #faf8f4;
    --sand: #d4c5a9;
    --terracotta: #b8704b;
    --terracotta-deep: #9a5a38;
    --moss-light: #6b7f6b;
    --stone: #8a8175;
    --stone-light: #b0a89c;
    --cream: #ede6d8;
    --charcoal: #2d2a26;
    --font-display: "Playfair Display", Georgia, serif;
    --font-body: "DM Sans", "Helvetica Neue", sans-serif;
    --font-accent: "Cormorant Garamond", Georgia, serif;
    --ease-soft: cubic-bezier(0.25, 0.1, 0.25, 1);
    --ease-out-soft: cubic-bezier(0, 0, 0.2, 1);
    --ease-editorial: cubic-bezier(0.16, 1, 0.3, 1);
    background: var(--warm-white);
    color: var(--ink);
    font-family: var(--font-body);
    line-height: 1.7;
    overflow-x: hidden;
    animation: edPageFade 0.5s var(--ease-editorial) both;
    /* Effect 2.8 — background cross-fades between sections */
    transition: background-color 1200ms var(--ease-soft);
  }
  .editor-page.bg-parchment { background: var(--parchment); }
  @keyframes edPageFade { from { opacity: 0; } to { opacity: 1; } }

  /* Effect 2.7 — sticky category label (quiet reader orientation cue) */
  .category-sticky-label {
    position: fixed; top: 5.5rem; left: 3rem; z-index: 900;
    font-family: var(--font-body); font-size: 11px; font-weight: 500;
    letter-spacing: 2px; text-transform: uppercase; color: var(--terracotta);
    background: rgba(250, 248, 244, 0.8);
    -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    padding: 0.45rem 0.9rem; border-radius: 2px;
    opacity: 0; pointer-events: none;
    transition: opacity 400ms var(--ease-soft);
  }
  .category-sticky-label.is-visible { opacity: 1; }
  @media (max-width: 639px) { .category-sticky-label { display: none; } }

  .editor-page ::selection {
    background: rgba(184, 112, 75, 0.2);
    color: #1a1714;
  }

  /* SCROLL REVEAL (editorial — slower, soft blur) */
  .editor-page .reveal {
    opacity: 0;
    transform: translateY(20px);
    filter: blur(3px);
    transition:
      opacity 900ms var(--ease-editorial),
      transform 900ms var(--ease-editorial),
      filter 900ms var(--ease-editorial);
    will-change: opacity, transform, filter;
  }
  .editor-page .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
  .editor-page .reveal-delay-1 { transition-delay: 120ms; }
  .editor-page .reveal-delay-2 { transition-delay: 240ms; }
  .editor-page .reveal-delay-3 { transition-delay: 360ms; }

  /* NAV */
  .ed-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 1.25rem 3rem;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(250, 248, 244, 0.92);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(26, 23, 20, 0.06);
  }
  .ed-nav-logo {
    font-family: var(--font-display); font-size: 1.4rem; font-weight: 500;
    color: var(--ink); text-decoration: none; letter-spacing: 0.02em;
    display: block;
  }
  .ed-nav-logo-img { height: 1.75rem; width: auto; display: block; }
  .ed-nav-links { display: flex; gap: 2.5rem; list-style: none; margin: 0; padding: 0; }
  .ed-nav-links a {
    font-family: var(--font-body); font-size: 0.82rem; font-weight: 400;
    color: var(--stone); text-decoration: none; letter-spacing: 0.08em;
    text-transform: uppercase; transition: color 0.3s ease; position: relative;
  }
  .ed-nav-links a:hover { color: var(--terracotta); }
  .ed-nav-links a::after {
    content: ""; position: absolute; bottom: -4px; left: 0;
    width: 0; height: 1px; background: currentColor; transition: width 400ms var(--ease-soft);
  }
  .ed-nav-links a:hover::after { width: 100%; }

  /* HERO */
  .editor-hero { padding: 10rem 6rem 5rem; max-width: 900px; }
  .editor-hero-badge {
    display: inline-block; font-family: var(--font-body); font-size: 0.65rem;
    font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--warm-white); background: var(--terracotta);
    padding: 0.4rem 1rem; margin-bottom: 2.5rem;
  }
  .editor-hero h1 {
    font-family: var(--font-display); font-size: clamp(2.8rem, 5.5vw, 4.2rem);
    font-weight: 400; line-height: 1.1; color: var(--ink);
    margin-bottom: 0; letter-spacing: -0.02em;
  }
  .editor-hero h1 em {
    font-style: italic; color: var(--terracotta);
    text-shadow: 0 1px 0 rgba(184,112,75,0.04);
    display: inline-block;
  }
  .editor-hero-tagline {
    font-family: var(--font-accent); font-style: italic; font-weight: 400;
    font-size: clamp(1.4rem, 2.4vw, 1.8rem); line-height: 1.4; color: var(--ink);
    margin-top: 0.75rem; margin-bottom: 2.5rem; max-width: 680px;
  }
  .editor-hero-intro {
    font-family: var(--font-accent); font-size: clamp(1.05rem, 1.4vw, 1.2rem); font-weight: 300;
    line-height: 1.85; color: var(--stone); max-width: 640px;
  }

  /* HERO LOAD SEQUENCE (Effect 2.1) */
  @keyframes edLoadUp { to { opacity: 1; transform: translateY(0); } }
  @keyframes edMaskReveal { to { opacity: 1; clip-path: inset(0 0 0 0); } }
  .ed-load { opacity: 0; will-change: opacity, transform; }
  .ed-load-badge   { transform: translateY(8px);  animation: edLoadUp 0.7s var(--ease-editorial) 0.4s forwards; }
  .ed-load-h1      { transform: translateY(20px); animation: edLoadUp 0.9s var(--ease-editorial) 0.6s forwards; }
  .ed-load-h1 em   {
    opacity: 0; clip-path: inset(0 100% 0 0);
    animation: edMaskReveal 0.6s var(--ease-editorial) 0.8s forwards;
  }
  .ed-load-tagline { transform: translateY(12px); animation: edLoadUp 0.7s var(--ease-editorial) 1s forwards; }
  .ed-load-intro1  { transform: translateY(12px); animation: edLoadUp 0.8s var(--ease-editorial) 1.2s forwards; }

  /* SECTION SHARED */
  .editor-page section { padding: 7rem 6rem; }
  .section-label {
    font-family: var(--font-body); font-size: 0.68rem; font-weight: 500;
    letter-spacing: 0.3em; text-transform: uppercase; color: var(--terracotta);
    margin-bottom: 2rem; display: flex; align-items: center; gap: 1.5rem;
  }
  .section-label::before { content: ""; width: 40px; height: 1px; background: var(--terracotta); }
  .section-heading {
    font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 400; line-height: 1.3; color: var(--ink); margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  /* STYLES OF WRITING */
  .styles-section { padding-top: 3rem; }
  .styles-header { margin-bottom: 3rem; }
  .styles-desc {
    font-family: var(--font-accent); font-style: italic; font-weight: 300;
    font-size: 1.2rem; color: var(--stone); line-height: 1.7;
  }
  .styles-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .style-card {
    display: flex; flex-direction: column;
