  // Effects 2.7 / 2.8 / 2.9 — sticky category label, background shift, active card.
  // One throttled scroll handler tracks which category section spans the viewport middle.
  const page = document.querySelector(".editor-page");
  const stickyLabel = document.querySelector(".category-sticky-label");
  const sections = Array.from(document.querySelectorAll("[data-category-section]"));
  const styleCards = Array.from(document.querySelectorAll(".style-card[data-category]"));
  let currentCategory = null;

  function setActiveCategory(section) {
    const id = section ? section.dataset.categorySection : null;
    if (id === currentCategory) return;
    currentCategory = id;

    if (stickyLabel) {
      if (section) {
        stickyLabel.textContent = section.dataset.categoryLabel;
        stickyLabel.classList.add("is-visible");
      } else {
        stickyLabel.classList.remove("is-visible");
      }
    }
    if (page) {
      page.classList.toggle("bg-parchment", !!section && section.dataset.bg === "parchment");
    }
    styleCards.forEach((card) => {
      card.classList.toggle("is-active", card.dataset.category === id);
    });
  }

  let categoryTick = false;
  function updateCategory() {
    const mid = window.innerHeight / 2;
    let active = null;
    for (const s of sections) {
      const rect = s.getBoundingClientRect();
      if (rect.top <= mid && rect.bottom >= mid) { active = s; break; }
    }
    setActiveCategory(active);
    categoryTick = false;
  }
  window.addEventListener("scroll", () => {
    if (!categoryTick) { categoryTick = true; requestAnimationFrame(updateCategory); }
  }, { passive: true });
  updateCategory();

  // Effect 2.5 fallback — JS parallax for browsers without animation-timeline: view().
  // Desktop only; disabled on mobile and for reduced motion.
  if (!reduceMotion && !isMobile && !CSS.supports("animation-timeline: view()")) {
    const cells = Array.from(document.querySelectorAll(".editor-page .bento-cell img"));
    let parallaxTick = false;
    const update = () => {
      const vh = window.innerHeight;
      for (const img of cells) {
        const cell = img.parentElement;
        const rect = cell.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > vh) continue;
        const progress = 1 - (rect.top + rect.height / 2) / (vh + rect.height);
        const max = cell.classList.contains("bento-cell-1") ? -12 : -8;
        img.style.transform = `translateY(${(progress * max).toFixed(2)}px)`;
      }
      parallaxTick = false;
    };
    const onScroll = () => {
      if (!parallaxTick) { parallaxTick = true; requestAnimationFrame(update); }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  }

  // Excerpt strips — pinned, scroll-linked right-to-left pan (nikhilthakkar.com feel).
  // The strip sticks in place while vertical scroll pans the images 1:1, so the
  // reader moves through every image before the section scrolls on.
  // Desktop/tablet only; on mobile the strip is a native horizontal swipe.
  if (!reduceMotion && !isMobile) {
    const strips = Array.from(document.querySelectorAll("[data-excerpt-pin]")).map((pin) => ({
      pin,
      strip: pin.querySelector("[data-excerpt-strip]"),
      track: pin.querySelector("[data-excerpt-track]"),
      overflow: 0,
      stickyTop: 0,
    }));
    const measure = () => {
      for (const s of strips) {
        s.pin.style.height = ""; // reset so strip height measures naturally
        s.overflow = Math.max(0, s.track.scrollWidth - s.strip.clientWidth);
        s.stickyTop = parseFloat(getComputedStyle(s.strip).top) || 0;
        if (s.overflow > 0) {
          // Extra scroll room equal to the hidden width -> 1:1 pan mapping
          s.pin.style.height = `${s.strip.offsetHeight + s.overflow}px`;
        }
      }
    };
    let stripTick = false;
    const updateStrips = () => {
      for (const s of strips) {
        if (s.overflow <= 0) continue;
        const rect = s.pin.getBoundingClientRect();
        // 0 while the pin hasn't reached its sticky offset; 1 when the pin's
        // extra scroll room is spent and the strip releases.
        let progress = (s.stickyTop - rect.top) / s.overflow;
        progress = Math.min(1, Math.max(0, progress));
        s.track.style.transform = `translate3d(${(-s.overflow * progress).toFixed(2)}px,0,0)`;
      }
      stripTick = false;
    };
    const onStripScroll = () => {
      if (!stripTick) { stripTick = true; requestAnimationFrame(updateStrips); }
    };
    // Recompute as images load — they're lazy, so each arrival widens its track
    const ready = () => { measure(); updateStrips(); };
    document.querySelectorAll("[data-excerpt-track] img").forEach((img) => {
      if (!img.complete) { img.addEventListener("load", ready); img.addEventListener("error", ready); }
    });
    measure();
    updateStrips();
    window.addEventListener("scroll", onStripScroll, { passive: true });
    window.addEventListener("resize", () => { measure(); updateStrips(); }, { passive: true });
  }
</script>
