---
import BaseLayout from "../layouts/BaseLayout.astro";

const themes = [
  {
    number: "01",
    titleLead: "Experiential Travel & ",
    titleEm: "Immersive Writing",
    bgAlt: false,
    desc: "Writing that puts the reader inside the moment — not observing a place, but feeling its temperature, hearing its rhythm, smelling its streets. Every sense engaged, every sentence earned through being there.",
    gallery: ["Ghats at dawn", "Street scene", "On the water"],
    excerpt:
      "The ghats of Varanasi do not greet you — they confront you. Before your feet find the first wet step, the city has already decided what it will show you: the smoke that curls upward carrying someone's last prayer, the marigold garlands sinking slowly into water that has held ten thousand years of faith.",
    citeTitle: "Varanasi",
    citeHref: "/blogs/varanasi",
    articles: [
      { title: "Varanasi — Here, you either find Him, or you lose faith in Him", pub: "Shunnoh", href: "/blogs/varanasi" },
      { title: "Goa's Glowing Forest — The Monsoon Treat", pub: "Shunnoh", href: "/blogs/goa" },
    ],
  },
  {
    number: "02",
    titleLead: "Destination ",
    titleEm: "Stories",
    bgAlt: true,
    desc: "Places told through their people, their food, their rituals. Not travel guides — travel stories. The kind that make a reader want to book a ticket or feel like they already have.",
    gallery: ["Sarnath", "Varanasi food", "Goa forest"],
    excerpt:
      "Stepping off the plane, I noticed a fellow passenger, an older gentleman, pause. The moment his foot touched the ground, he set his luggage aside and, with a reverent bow, touched his forehead to the cold tarmac — a silent, heartfelt greeting to the sacred city.",
    citeTitle: "Varanasi",
    citeHref: "/blogs/varanasi",
    articles: [
      { title: "Sarnath — Where the Wheel of Dharma was Turned", pub: "Shunnoh", href: "/blogs/sarnath" },
      { title: "Best Foods in Varanasi — Your Guide to Iconic Local Flavors", pub: "Shunnoh", href: "/blogs/varanasi-food" },
    ],
  },
  {
    number: "03",
    titleLead: "Culture & ",
    titleEm: "Heritage",
    bgAlt: false,
    desc: "The living traditions that define a place — festivals, rituals, sacred spaces, and the unwritten rules that bind communities. Writing that honours the people who keep these traditions alive.",
    gallery: ["Ganga aarti", "Temple", "Daily ritual"],
    excerpt:
      "As dusk paints the Varanasi sky in hues of orange and purple, Dashashwamedh Ghat transforms into a stage for the mesmerizing Ganga Aarti. The air buzzes with anticipation as priests, clad in vibrant silk robes, prepare for the ceremony.",
    citeTitle: "Varanasi",
    citeHref: "/blogs/varanasi",
    articles: [
      { title: "Varanasi — Ganga Aarti, Manikarnika & the Sacred Ghats", pub: "Shunnoh", href: "/blogs/varanasi" },
    ],
  },
  {
    number: "04",
    titleLead: "Craft & ",
    titleEm: "Living History",
    bgAlt: true,
    desc: "The artisans, the looms, the hands that shape heritage. Stories that trace a craft from its mythological origins to the workshop floor today — making the reader care about traditions they've never seen.",
    gallery: ["The loom", "Weaver's hands", "The fabric"],
    excerpt:
      "A Banarasi saree is never merely worn. It is inherited, gifted, wept over, and remembered. The weavers of Varanasi don't make fabric — they make heirlooms. And in their looms, you can hear the rhythm of a tradition that has dressed gods, adorned royalty, and now drapes the shoulders of a woman walking into her own story.",
    citeTitle: "The Banarasi Saree",
    citeHref: "/blogs/banarasi-saree",
    articles: [
      { title: "The Banarasi Saree — From the Gods, through the Royals, to the Masses", pub: "Shunnoh", href: "/blogs/banarasi-saree" },
    ],
  },
];

const skills = [
  "Consumer Research (Nielsen)", "Data & Insights", "SEO & Content Strategy",
  "Editorial Writing", "Travel Photography", "Cultural Research", "Hindi · Bengali · English",
];
---
<BaseLayout title="For Editors — Shunnoh" description="Barnali's editorial portfolio — immersive travel writing, cultural features, and destination storytelling for publications." noindex={true}>
  <div class="editor-page paper-texture">
    <!-- NAV (frosted) -->
    <nav class="ed-nav">
      <a href="/" class="ed-nav-logo" aria-label="Shunnoh — home"><img src="/images/branding/logo-wordmark-dark.svg" alt="Shunnoh" class="ed-nav-logo-img" width="210" height="48" /></a>
      <ul class="ed-nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blogs">Blog</a></li>
        <li><a href="#contact">Get in Touch</a></li>
      </ul>
    </nav>

    <!-- HERO -->
    <section class="editor-hero">
      <div class="editor-hero-badge fade-up fade-up-1">For Editors &amp; Publications</div>
      <h1 class="fade-up fade-up-2">I write the kind of travel stories readers <em>remember.</em></h1>
      <p class="editor-hero-intro fade-up fade-up-3">I'm Barnali, the writer behind Shunnoh. I specialise in immersive, research-rich travel features — the kind where a reader doesn't just learn about a place, they feel like they've been there. If your publication values depth, sensory detail, and cultural authenticity over listicles and SEO filler, we should talk.</p>
    </section>

    <!-- THEME SECTIONS -->
    {themes.map((t) => (
      <section class={`theme-section ${t.bgAlt ? "bg-alt" : ""}`}>
        <div class="theme-header reveal">
          <div class="theme-number">{t.number}</div>
          <h2 class="theme-title">{t.titleLead}<em>{t.titleEm}</em></h2>
          <p class="theme-desc">{t.desc}</p>
        </div>

        <div class="theme-gallery reveal reveal-delay-1">
          {t.gallery.map((label) => (
            <div class="theme-gallery-item">{label}</div>
          ))}
        </div>

        <div class="theme-excerpt reveal reveal-delay-2">
          <blockquote>{t.excerpt}</blockquote>
          <cite>— from <a href={t.citeHref}>{t.citeTitle}</a></cite>
        </div>

        <ul class="theme-articles reveal reveal-delay-2">
          {t.articles.map((a) => (
            <li>
              <a href={a.href} class="theme-article-link">
                <span class="theme-article-title">{a.title}</span>
                <span class="theme-article-pub">{a.pub}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <!-- PUBLISHED ACROSS -->
    <section class="published-across reveal">
      <div class="section-label" style="justify-content:center;color:var(--sand);">Published Across</div>
      <h2 class="section-heading" style="color:var(--parchment);">Work that's found its audience.</h2>
      <div class="pub-logos">
        <span class="pub-logo">Outlook Traveller Eats</span>
        <span class="pub-divider"></span>
        <span class="pub-logo">Shunnoh</span>
        <span class="pub-divider"></span>
        <span class="pub-logo">More coming soon</span>
      </div>
    </section>

    <!-- ABOUT BARNALI -->
    <section class="about-barnali">
      <div class="about-layout">
        <div class="about-photo reveal">Barnali — portrait</div>
        <div class="about-text reveal reveal-delay-1">
          <div class="section-label">About the Writer</div>
          <h2>Research runs deep. The writing makes it <em>sing.</em></h2>
          <p>Before Shunnoh, I spent years at Nielsen — working across research, consumer insights, and data strategy. That training didn't disappear when I picked up a notebook. It shaped the writer I became.</p>
          <p>Every Shunnoh piece begins with deep, structured research — historical records, conversations with artisans, local archives, cultural context most writers skip. The difference between a travel blog and a Shunnoh feature is that the homework is done before the first sentence is written. The loom techniques in the Banarasi Saree piece, the mythology behind Manikarnika — none of that is surface-level Googling. It's fieldwork.</p>
          <p>But research alone doesn't make someone read to the end. What I bring is the ability to take that depth and weave it into narrative — sensory, immersive, human. The reader gets the rigour without feeling the weight. They get a story that's meticulously accurate and genuinely enjoyable to read.</p>
          <p>That combination — the researcher's discipline and the writer's instinct — is what I offer your publication.</p>
          <div class="about-skills">
            {skills.map((s) => <span class="about-skill-tag">{s}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="editor-contact" id="contact">
      <h2 class="reveal">Interested in <em>working together?</em></h2>
      <p class="editor-contact-sub reveal reveal-delay-1">I'm open to commissions, contributor roles, and editorial collaborations. Happy to discuss rates, adapt to your house style, or send full drafts of any unpublished piece.</p>
      <a href="mailto:hello@shunnoh.com" class="editor-contact-email reveal reveal-delay-2">hello@shunnoh.com</a>
      <div class="editor-contact-links reveal reveal-delay-2">
        <a href="https://www.instagram.com/shunnoh_" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://x.com/shunnoh_blog" target="_blank" rel="noopener noreferrer">Twitter / X</a>
        <a href="https://www.linkedin.com/in/barnali" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
      <div class="editor-cta-explore reveal reveal-delay-3">
        <a href="/">Explore Shunnoh
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="ed-footer">
      <p>&copy; 2026 Shunnoh. All rights reserved.</p>
      <p>This page is shared privately with editors and publications.</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .editor-page {
    --ink: #1a1714;
    --parchment: #f5f0e8;
    --warm-white: #faf8f4;
    --sand: #d4c5a9;
    --terracotta: #b8704b;
    --terracotta-deep: #9a5a38;
    --moss-light: #6b7f6b;
    --stone: #8a8175;
    --stone-light: #b0a89c;
    --cream: #ede6d8;
    --charcoal: #2d2a26;
    --font-display: "Playfair Display", Georgia, serif;
    --font-body: "DM Sans", "Helvetica Neue", sans-serif;
    --font-accent: "Cormorant Garamond", Georgia, serif;
    background: var(--warm-white);
    color: var(--ink);
    font-family: var(--font-body);
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* NAV */
  .ed-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 1.25rem 3rem;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(250, 248, 244, 0.92);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(26, 23, 20, 0.06);
  }
  .ed-nav-logo {
    font-family: var(--font-display); font-size: 1.4rem; font-weight: 500;
    color: var(--ink); text-decoration: none; letter-spacing: 0.02em;
    display: block;
  }
  .ed-nav-logo-img { height: 1.75rem; width: auto; display: block; }
  .ed-nav-links { display: flex; gap: 2.5rem; list-style: none; margin: 0; padding: 0; }
  .ed-nav-links a {
    font-family: var(--font-body); font-size: 0.82rem; font-weight: 400;
    color: var(--stone); text-decoration: none; letter-spacing: 0.08em;
    text-transform: uppercase; transition: color 0.3s ease; position: relative;
  }
  .ed-nav-links a:hover { color: var(--terracotta); }
  .ed-nav-links a::after {
    content: ""; position: absolute; bottom: -4px; left: 0;
    width: 0; height: 1px; background: currentColor; transition: width 0.3s ease;
  }
  .ed-nav-links a:hover::after { width: 100%; }

  /* HERO */
  .editor-hero { padding: 10rem 6rem 5rem; max-width: 900px; }
  .editor-hero-badge {
    display: inline-block; font-family: var(--font-body); font-size: 0.65rem;
    font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--warm-white); background: var(--terracotta);
    padding: 0.4rem 1rem; margin-bottom: 2.5rem;
  }
  .editor-hero h1 {
    font-family: var(--font-display); font-size: clamp(2.4rem, 4.5vw, 3.5rem);
    font-weight: 400; line-height: 1.2; color: var(--ink);
    margin-bottom: 2rem; letter-spacing: -0.01em;
  }
  .editor-hero h1 em { font-style: italic; color: var(--terracotta); }
  .editor-hero-intro {
    font-family: var(--font-accent); font-size: 1.25rem; font-weight: 300;
    line-height: 1.85; color: var(--charcoal); max-width: 680px;
  }

  /* SECTION SHARED */
  .editor-page section { padding: 5rem 6rem; }
  .section-label {
    font-family: var(--font-body); font-size: 0.68rem; font-weight: 500;
    letter-spacing: 0.3em; text-transform: uppercase; color: var(--terracotta);
    margin-bottom: 2rem; display: flex; align-items: center; gap: 1.5rem;
  }
  .section-label::before { content: ""; width: 40px; height: 1px; background: var(--terracotta); }
  .section-heading {
    font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 400; line-height: 1.3; color: var(--ink); margin-bottom: 1.5rem;
  }

  /* THEME SECTIONS */
  .theme-section { padding: 5rem 6rem; border-top: 1px solid rgba(26,23,20,0.06); }
  .theme-section.bg-alt { background: var(--parchment); }
  .theme-header { max-width: 500px; margin-bottom: 3rem; }
  .theme-number { font-family: var(--font-display); font-size: 0.85rem; color: var(--stone-light); margin-bottom: 0.75rem; }
  .theme-title { font-family: var(--font-display); font-size: clamp(1.5rem, 2.2vw, 2rem); font-weight: 400; line-height: 1.3; margin-bottom: 1rem; color: var(--ink); }
  .theme-title em { font-style: italic; color: var(--terracotta); }
  .theme-desc { font-family: var(--font-accent); font-size: 1.05rem; font-weight: 300; line-height: 1.8; color: var(--stone); }

  .theme-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2.5rem; }
  .theme-gallery-item { aspect-ratio: 4/3; background: var(--sand); display: flex; align-items: center; justify-content: center; font-family: var(--font-body); font-size: 0.55rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--stone); overflow: hidden; transition: transform 0.5s ease; }
  .theme-gallery-item:hover { transform: scale(1.02); }

  .theme-excerpt { border-left: 3px solid var(--terracotta); padding-left: 2rem; margin-bottom: 2.5rem; max-width: 650px; }
  .theme-excerpt blockquote { font-family: var(--font-accent); font-size: 1.15rem; font-weight: 300; font-style: italic; line-height: 1.9; color: var(--ink); }
  .theme-excerpt cite { display: block; font-family: var(--font-body); font-size: 0.7rem; font-style: normal; letter-spacing: 0.08em; color: var(--stone); margin-top: 0.75rem; }
  .theme-excerpt cite a { color: var(--terracotta); text-decoration: none; border-bottom: 1px solid rgba(184,112,75,0.3); transition: border-color 0.3s; }
  .theme-excerpt cite a:hover { border-color: var(--terracotta); }

  .theme-articles { list-style: none; padding: 0; }
  .theme-articles li { padding: 1rem 0; border-bottom: 1px solid rgba(26,23,20,0.06); }
  .theme-articles li:first-child { border-top: 1px solid rgba(26,23,20,0.06); }
  .theme-article-link { display: flex; justify-content: space-between; align-items: center; text-decoration: none; color: var(--ink); transition: color 0.3s; }
  .theme-article-link:hover { color: var(--terracotta); }
  .theme-article-title { font-family: var(--font-display); font-size: 1.05rem; font-weight: 500; }
  .theme-article-pub { font-family: var(--font-body); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--stone); white-space: nowrap; margin-left: 2rem; }

  /* PUBLISHED ACROSS */
  .published-across { background: var(--charcoal); color: var(--parchment); padding: 4rem 6rem; text-align: center; }
  .pub-logos { display: flex; justify-content: center; align-items: center; gap: 3rem; flex-wrap: wrap; margin-top: 2.5rem; }
  .pub-logo { font-family: var(--font-display); font-size: 1.1rem; font-weight: 400; font-style: italic; color: var(--stone-light); transition: color 0.3s; white-space: nowrap; }
  .pub-logo:hover { color: var(--parchment); }
  .pub-divider { width: 1px; height: 20px; background: rgba(176,168,156,0.3); }

  /* ABOUT BARNALI */
  .about-barnali { padding: 5rem 6rem; border-top: 1px solid rgba(26,23,20,0.06); }
  .about-layout { display: grid; grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: start; }
  .about-photo { aspect-ratio: 3/4; background: var(--sand); display: flex; align-items: center; justify-content: center; font-family: var(--font-body); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--stone); }
  .about-text h2 { font-family: var(--font-display); font-size: clamp(1.5rem, 2.2vw, 2rem); font-weight: 400; line-height: 1.35; margin-bottom: 1.75rem; color: var(--ink); }
  .about-text h2 em { font-style: italic; color: var(--terracotta); }
  .about-text p { font-family: var(--font-accent); font-size: 1.05rem; font-weight: 300; line-height: 1.85; color: var(--stone); margin-bottom: 1.25rem; }
  .about-skills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(26,23,20,0.08); }
  .about-skill-tag { font-family: var(--font-body); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.4rem 0.85rem; border: 1px solid var(--sand); color: var(--stone); transition: all 0.3s; }
  .about-skill-tag:hover { border-color: var(--terracotta); color: var(--terracotta); }

  /* CONTACT */
  .editor-contact { padding: 6rem; text-align: center; background: var(--parchment); }
  .editor-contact h2 { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 400; color: var(--ink); margin-bottom: 1rem; }
  .editor-contact h2 em { font-style: italic; color: var(--terracotta); }
  .editor-contact-sub { font-family: var(--font-accent); font-size: 1.1rem; font-weight: 300; color: var(--stone); max-width: 500px; margin: 0 auto 2.5rem; line-height: 1.7; }
  .editor-contact-email {
    display: inline-block; font-family: var(--font-display); font-size: 1.3rem; color: var(--ink);
    text-decoration: none; border-bottom: 1px solid var(--sand); padding-bottom: 0.25rem; transition: border-color 0.3s ease;
  }
  .editor-contact-email:hover { border-color: var(--terracotta); }
  .editor-contact-links { display: flex; justify-content: center; gap: 2rem; margin-top: 2rem; }
  .editor-contact-links a { font-family: var(--font-body); font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--stone); text-decoration: none; transition: color 0.3s; }
  .editor-contact-links a:hover { color: var(--terracotta); }
  .editor-cta-explore { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--sand); }
  .editor-cta-explore a {
    display: inline-flex; align-items: center; gap: 0.6rem; font-family: var(--font-body);
    font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--terracotta);
    text-decoration: none; transition: gap 0.3s ease;
  }
  .editor-cta-explore a:hover { gap: 1rem; }
  .editor-cta-explore svg { width: 16px; height: 16px; }

  /* FOOTER */
  .ed-footer { background: var(--ink); padding: 2rem 6rem; display: flex; justify-content: space-between; align-items: center; }
  .ed-footer p { font-family: var(--font-body); font-size: 0.72rem; color: var(--stone); letter-spacing: 0.05em; }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .editor-page section, .editor-hero, .editor-contact,
    .theme-section, .about-barnali, .published-across { padding-left: 3rem; padding-right: 3rem; }
    .about-layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-photo { max-width: 400px; }
    .ed-nav { padding: 1.25rem 1.5rem; }
    .ed-footer { padding: 2rem 3rem; }
  }
  @media (max-width: 768px) {
    .theme-section, .about-barnali, .published-across { padding-left: 1.5rem; padding-right: 1.5rem; }
    .theme-gallery { grid-template-columns: 1fr 1fr; }
    .theme-article-link { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
    .theme-article-pub { margin-left: 0; }
    .pub-logos { gap: 1.5rem; }
    .pub-divider { display: none; }
  }
  @media (max-width: 640px) {
    .editor-page section, .editor-hero, .editor-contact { padding-left: 1.5rem; padding-right: 1.5rem; }
    .editor-hero { padding-top: 7rem; }
    .ed-nav-links { gap: 1.2rem; }
    .ed-nav-links a { font-size: 0.68rem; }
    .ed-footer { padding: 2rem 1.5rem; flex-direction: column; gap: 0.5rem; text-align: center; }
  }
  @media (max-width: 480px) {
    .theme-gallery { grid-template-columns: 1fr; }
  }
</style>

<script>
  const reveals = document.querySelectorAll(".editor-page .reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible", "visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
  );
  reveals.forEach((el) => observer.observe(el));

  document.querySelectorAll('.editor-page a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", function (e) {
      const id = this.getAttribute("href");
      const target = document.querySelector(id);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  });
</script>
