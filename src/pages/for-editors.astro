    background-repeat: no-repeat; background-position: 0 100%; background-size: 0% 1px;
    align-self: flex-start;
    transition: color 400ms var(--ease-soft), background-size 500ms var(--ease-out-soft);
  }
  a.article-card:hover .article-card-title { color: var(--terracotta); background-size: 100% 1px; transition: color 600ms var(--ease-soft), background-size 500ms var(--ease-out-soft); }
  .article-card-city {
    font-family: var(--font-body); font-size: 10px; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--stone-light);
    margin-bottom: 0.25rem;
  }
  .article-card-pub {
    font-family: var(--font-body); font-size: 11px; font-weight: 500;
    color: var(--terracotta); margin-bottom: 0.6rem;
  }
  .article-card-preview {
    font-family: var(--font-accent); font-size: 15px; font-style: italic;
    font-weight: 300; line-height: 1.6; color: var(--stone);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card-soon { opacity: 0.85; cursor: default; }

  /* BENTO GALLERY */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 200px 200px 200px;
    gap: 1rem;
    margin-bottom: 4.5rem;
  }
  .bento-cell {
    overflow: hidden; border-radius: 12px; background: var(--cream);
  }
  .bento-cell img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
    transition: transform 200ms ease;
  }
  .bento-cell:hover img { transform: scale(1.03); }
  .bento-cell-1 { grid-column: 1 / span 2; grid-row: 1 / span 2; }
  .bento-cell-2 { grid-column: 3 / span 2; grid-row: 1; }
  .bento-cell-3 { grid-column: 3; grid-row: 2; }
  .bento-cell-4 { grid-column: 4; grid-row: 2; }
  .bento-cell-5 { grid-column: 3 / span 2; grid-row: 3; }

  /* Effect 2.3 (5) — bento cells reveal with a clip-path from the bottom, curtains lifting */
  .bento-grid .bento-cell {
    clip-path: inset(100% 0 0 0);
    transition: clip-path 900ms var(--ease-editorial);
  }
  .bento-grid.is-visible .bento-cell { clip-path: inset(0 0 0 0); }
  .bento-grid .bento-cell-2 { transition-delay: 150ms; }
  .bento-grid .bento-cell-3 { transition-delay: 300ms; }
  .bento-grid .bento-cell-4 { transition-delay: 450ms; }
  .bento-grid .bento-cell-5 { transition-delay: 600ms; }

  /* Effect 2.5 — very subtle scroll-linked parallax on bento cells (desktop only) */
  @supports (animation-timeline: view()) {
    @media (min-width: 640px) and (prefers-reduced-motion: no-preference) {
      .bento-grid.is-visible .bento-cell img {
        animation: bentoParallaxSmall linear both;
        animation-timeline: view();
        animation-range: entry 0% exit 100%;
      }
      .bento-grid.is-visible .bento-cell-1 img { animation-name: bentoParallaxLarge; }
    }
  }
  @keyframes bentoParallaxLarge {
    from { transform: translateY(0); }
    to   { transform: translateY(-12px); }
  }
  @keyframes bentoParallaxSmall {
    from { transform: translateY(0); }
    to   { transform: translateY(-8px); }
  }

  /* EXCERPTS */
  .category-excerpts { margin-bottom: 1rem; }
  .theme-excerpt {
    position: relative;
    padding-left: 2.5rem; margin-bottom: 3rem; max-width: 650px;
  }
  .theme-excerpt:last-child { margin-bottom: 0; }
  .theme-excerpt::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px; background: rgba(184,112,75,0.7);
  }
  .theme-excerpt blockquote {
    font-family: var(--font-accent); font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    font-weight: 300; font-style: italic; line-height: 1.7; color: var(--ink);
    letter-spacing: -0.005em;
  }

  /* Effect 2.6 — border draws itself top-to-bottom while the text fades in */
  .theme-excerpt.reveal {
    opacity: 1; transform: none; filter: none;
    transition: none;
  }
  .theme-excerpt.reveal::before {
    transform: scaleY(0); transform-origin: top;
    transition: transform 400ms var(--ease-editorial);
  }
  .theme-excerpt.reveal blockquote {
    opacity: 0;
    transition: opacity 600ms var(--ease-editorial);
  }
  .theme-excerpt.reveal.is-visible::before { transform: scaleY(1); }
  .theme-excerpt.reveal.is-visible blockquote { opacity: 1; }

  /* ABOUT BARNALI */
  .editor-page .about-barnali { padding: 7rem 6rem; position: relative; }
  .about-layout { display: grid; grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: start; }
  .about-photo { aspect-ratio: 3/4; background: var(--sand); display: flex; align-items: center; justify-content: center; font-family: var(--font-body); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--stone); }
  .about-text h2 { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 400; line-height: 1.25; letter-spacing: -0.01em; margin-bottom: 1.75rem; color: var(--ink); }
  .about-text h2 em { font-style: italic; color: rgba(184,112,75,0.9); text-shadow: 0 1px 0 rgba(184,112,75,0.04); }
  .about-text p { font-family: var(--font-accent); font-size: 1.05rem; font-weight: 300; line-height: 1.85; color: var(--stone); margin-bottom: 1.5rem; }
  .about-skills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(26,23,20,0.08); }
  .about-skill-tag { font-family: var(--font-body); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.4rem 0.85rem; border: 1px solid var(--sand); color: var(--stone); cursor: default; transition: all 0.3s var(--ease-soft); }
  .about-skill-tag:hover { border-color: var(--terracotta); color: var(--terracotta); }

  /* CONTACT */
  .editor-contact { padding: 7rem 6rem; text-align: center; background: var(--parchment); position: relative; }
  .editor-contact h2 { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 400; color: var(--ink); margin-bottom: 1rem; }
  .editor-contact h2 em { font-style: italic; color: var(--terracotta); }
  .editor-contact-sub { font-family: var(--font-accent); font-size: 1.1rem; font-weight: 300; color: var(--stone); max-width: 500px; margin: 0 auto 2.5rem; line-height: 1.7; }
  .editor-contact-email {
    display: inline-block; font-family: var(--font-display); font-size: 1.3rem; color: var(--ink);
    text-decoration: none; border-bottom: 1px solid var(--sand); padding-bottom: 0.25rem; transition: border-color 0.3s ease;
  }
  .editor-contact-email:hover { border-color: var(--terracotta); }
  .editor-contact-links { display: flex; justify-content: center; gap: 2rem; margin-top: 2rem; }
  .editor-contact-links a { font-family: var(--font-body); font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--stone); text-decoration: none; transition: color 0.3s; }
  .editor-contact-links a:hover { color: var(--terracotta); }
  .editor-cta-explore { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--sand); }
  .editor-cta-explore a {
    display: inline-flex; align-items: center; gap: 0.6rem; font-family: var(--font-body);
    font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--terracotta);
    text-decoration: none; transition: transform 500ms var(--ease-editorial);
