  .editor-cta-explore svg { width: 16px; height: 16px; transition: transform 500ms var(--ease-editorial); }
  .editor-cta-explore a:hover svg { transform: translateX(4px); animation: ctaNudge 500ms var(--ease-editorial); }
  @keyframes ctaNudge { 0% { transform: translateX(4px) scale(1); } 50% { transform: translateX(4px) scale(1.1); } 100% { transform: translateX(4px) scale(1); } }

  /* FOOTER */
  .ed-footer { background: var(--ink); padding: 2rem 6rem; display: flex; justify-content: space-between; align-items: center; }
  .ed-footer p { font-family: var(--font-body); font-size: 0.72rem; color: var(--stone); letter-spacing: 0.05em; }

  /* RESPONSIVE */
  @media (max-width: 1023px) {
    .editor-page section, .editor-hero, .editor-contact { padding-left: 3rem; padding-right: 3rem; }
    .editor-page .category-section { padding: 5rem 3rem; }
    .editor-page .about-barnali { padding: 5rem 3rem; }
    .about-layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-photo { max-width: 400px; }
    .ed-nav { padding: 1.25rem 1.5rem; }
    .ed-footer { padding: 2rem 3rem; }
    .styles-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .article-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    /* Bento: simplify to 2-col, equal 4/3 cells */
    .bento-grid { grid-template-columns: 1fr 1fr; grid-template-rows: none; grid-auto-rows: auto; }
    .bento-cell { grid-column: auto !important; grid-row: auto !important; aspect-ratio: 4/3; }
  }
  @media (max-width: 639px) {
    .editor-page section, .editor-hero, .editor-contact { padding-left: 1.5rem; padding-right: 1.5rem; }
    .editor-page .category-section, .editor-page .about-barnali { padding: 4rem 1.5rem; }
    .editor-hero { padding-top: 7rem; }
    .ed-nav-links { gap: 1.2rem; }
    .ed-nav-links a { font-size: 0.68rem; }
    .ed-footer { padding: 2rem 1.5rem; flex-direction: column; gap: 0.5rem; text-align: center; }
    .styles-grid { grid-template-columns: 1fr; }
    .article-grid { grid-template-columns: 1fr; }
    .bento-grid { grid-template-columns: 1fr; }
  }

  /* REDUCED MOTION */
  @media (prefers-reduced-motion: reduce) {
    .editor-page { animation: none; transition: none; }
    .editor-page .reveal,
    .theme-excerpt.reveal blockquote,
    .category-header .category-number,
    .category-header .category-title,
    .category-header .category-title em,
    .category-header .category-line {
      opacity: 1 !important; transform: none !important; filter: none !important; clip-path: none !important;
    }
    .theme-excerpt.reveal::before { transform: none !important; }
    .bento-grid .bento-cell { clip-path: none !important; }
    .ed-load, .ed-load-h1 em {
      opacity: 1 !important; transform: none !important; animation: none !important; clip-path: none !important;
    }
    .editor-cta-explore a:hover svg { animation: none; }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const isMobile = window.matchMedia("(max-width: 639px)").matches;

  // Scroll reveal — .reveal elements plus the staged category headers and bento grids
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
  );
  document
    .querySelectorAll(".editor-page .reveal, .editor-page .category-header, .editor-page .bento-grid")
    .forEach((el) => observer.observe(el));

  // Smooth anchor scroll (nav + style cards). Targets carry scroll-margin-top: 96px.
  document.querySelectorAll('.editor-page a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", function (e) {
      const target = document.querySelector(this.getAttribute("href"));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  });

  // Effects 2.7 / 2.8 / 2.9 — sticky category label, background shift, active card.
  // One throttled scroll handler tracks which category section spans the viewport middle.
  const page = document.querySelector(".editor-page");
  const stickyLabel = document.querySelector(".category-sticky-label");
  const sections = Array.from(document.querySelectorAll("[data-category-section]"));
  const styleCards = Array.from(document.querySelectorAll(".style-card[data-category]"));
  let currentCategory = null;

  function setActiveCategory(section) {
    const id = section ? section.dataset.categorySection : null;
    if (id === currentCategory) return;
    currentCategory = id;

    if (stickyLabel) {
      if (section) {
        stickyLabel.textContent = section.dataset.categoryLabel;
        stickyLabel.classList.add("is-visible");
      } else {
        stickyLabel.classList.remove("is-visible");
      }
    }
    if (page) {
      page.classList.toggle("bg-parchment", !!section && section.dataset.bg === "parchment");
    }
    styleCards.forEach((card) => {
      card.classList.toggle("is-active", card.dataset.category === id);
    });
  }

  let categoryTick = false;
  function updateCategory() {
    const mid = window.innerHeight / 2;
    let active = null;
    for (const s of sections) {
      const rect = s.getBoundingClientRect();
      if (rect.top <= mid && rect.bottom >= mid) { active = s; break; }
    }
    setActiveCategory(active);
    categoryTick = false;
  }
  window.addEventListener("scroll", () => {
    if (!categoryTick) { categoryTick = true; requestAnimationFrame(updateCategory); }
  }, { passive: true });
  updateCategory();

  // Effect 2.5 fallback — JS parallax for browsers without animation-timeline: view().
  // Desktop only; disabled on mobile and for reduced motion.
  if (!reduceMotion && !isMobile && !CSS.supports("animation-timeline: view()")) {
    const cells = Array.from(document.querySelectorAll(".editor-page .bento-cell img"));
    let parallaxTick = false;
    const update = () => {
      const vh = window.innerHeight;
      for (const img of cells) {
        const cell = img.parentElement;
        const rect = cell.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > vh) continue;
        const progress = 1 - (rect.top + rect.height / 2) / (vh + rect.height);
        const max = cell.classList.contains("bento-cell-1") ? -12 : -8;
        img.style.transform = `translateY(${(progress * max).toFixed(2)}px)`;
      }
      parallaxTick = false;
    };
    const onScroll = () => {
      if (!parallaxTick) { parallaxTick = true; requestAnimationFrame(update); }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  }
</script>
