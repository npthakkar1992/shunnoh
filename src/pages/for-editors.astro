    border: 1px solid var(--sand);
    border-radius: 12px;
    padding: 2rem;
    text-decoration: none;
    transition: transform 400ms ease, border-color 400ms ease;
  }
  /* Effect 2.2 — cards stagger in from bottom with blur clearance */
  .style-card.reveal {
    transform: translateY(24px);
    transition:
      opacity 800ms var(--ease-editorial),
      transform 800ms var(--ease-editorial), border-color 400ms ease,
      filter 800ms var(--ease-editorial);
  }
  .styles-grid .style-card:nth-child(2) { transition-delay: 140ms; }
  .styles-grid .style-card:nth-child(3) { transition-delay: 280ms; }
  .styles-grid .style-card.is-visible:hover { transition-delay: 0ms; }
  .style-card:hover {
    transform: translateY(-3px);
    border-color: rgba(184, 112, 75, 0.6);
  }
  .style-card.is-active {
    border-color: var(--terracotta);
  }
  .style-card.is-active .style-card-number { color: var(--terracotta); }
  .style-card-number {
    font-family: var(--font-display); font-size: 0.85rem; color: var(--stone-light);
    margin-bottom: 1rem; transition: color 400ms ease;
  }
  .style-card-title {
    font-family: var(--font-display); font-size: 1.25rem; font-weight: 500;
    line-height: 1.35; color: var(--ink); margin-bottom: 0.6rem;
  }
  .style-card-line {
    font-family: var(--font-accent); font-style: italic; font-weight: 300;
    font-size: 1rem; line-height: 1.6; color: var(--stone); margin-bottom: 1.5rem;
  }
  .style-card-img {
    display: block; margin-top: auto; aspect-ratio: 5/2; overflow: hidden;
    border-radius: 8px; background: var(--cream);
  }
  .style-card-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 800ms var(--ease-soft);
  }
  .style-card:hover .style-card-img img { transform: scale(1.04); }

  /* CATEGORY SECTIONS */
  .editor-page .category-section { padding: 7rem 6rem; position: relative; scroll-margin-top: 96px; }
  .category-section + .category-section::before,
  .about-barnali::before,
  .editor-contact::before {
    content: ""; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 200px; max-width: 60%; height: 1px;
    background: linear-gradient(to right, transparent, rgba(26,23,20,0.08), transparent);
  }
  /* Section fill stays transparent — the page background cross-fades instead (Effect 2.8) */
  .category-section.bg-alt { background: transparent; }
  .category-section.bg-alt::after {
    content: ""; position: absolute; inset: 0; pointer-events: none; z-index: 0;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }
  .category-section.bg-alt > * { position: relative; z-index: 1; }
  .category-header { max-width: 540px; margin-bottom: 3.5rem; }
  .category-number { font-family: var(--font-display); font-size: 0.85rem; color: #a39e93; margin-bottom: 0.75rem; }
  .category-title { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 400; line-height: 1.25; letter-spacing: -0.01em; margin-bottom: 1rem; color: var(--ink); }
  .category-title em { font-style: italic; color: rgba(184,112,75,0.9); text-shadow: 0 1px 0 rgba(184,112,75,0.04); display: inline-block; }
  .category-line { font-family: var(--font-accent); font-size: 1.1rem; font-weight: 300; line-height: 1.7; color: var(--stone); max-width: 500px; }

  /* Effect 2.3 — staged category entry: number → title → em (mask) → description */
  .category-header .category-number {
    opacity: 0; transform: translateX(-8px);
    transition: opacity 400ms var(--ease-editorial), transform 400ms var(--ease-editorial);
  }
  .category-header .category-title {
    opacity: 0; transform: translateY(16px);
    transition: opacity 900ms var(--ease-editorial) 600ms, transform 900ms var(--ease-editorial) 600ms;
  }
  .category-header .category-title em {
    opacity: 0; clip-path: inset(0 100% 0 0);
    transition: opacity 600ms var(--ease-editorial) 800ms, clip-path 600ms var(--ease-editorial) 800ms;
  }
  .category-header .category-line {
    opacity: 0; transform: translateY(12px);
    transition: opacity 800ms var(--ease-editorial) 800ms, transform 800ms var(--ease-editorial) 800ms;
  }
  .category-header.is-visible .category-number { opacity: 1; transform: translateX(0); }
  .category-header.is-visible .category-title { opacity: 1; transform: translateY(0); }
  .category-header.is-visible .category-title em { opacity: 1; clip-path: inset(0 0 0 0); }
  .category-header.is-visible .category-line { opacity: 1; transform: translateY(0); }

  /* ARTICLE GRID */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  .article-card {
    display: flex; flex-direction: column;
    text-decoration: none;
  }
  /* Effect 2.3 (4) — article cards stagger in, 100ms between cards */
  .article-card.reveal {
    transition:
      opacity 700ms var(--ease-editorial),
      transform 700ms var(--ease-editorial),
      filter 700ms var(--ease-editorial);
  }
  .article-grid .article-card:nth-child(2) { transition-delay: 100ms; }
  .article-grid .article-card:nth-child(3) { transition-delay: 200ms; }
  .article-grid .article-card.is-visible:hover { transition-delay: 0ms; }
  .article-card-imgwrap {
    display: block; aspect-ratio: 4/3; overflow: hidden;
    border-radius: 8px; background: var(--cream); margin-bottom: 1.1rem;
  }
  .article-card-img {
    display: block; width: 100%; height: 100%; object-fit: cover;
    transition: transform 800ms var(--ease-soft), filter 800ms var(--ease-soft);
  }
  a.article-card:hover .article-card-img {
    transform: scale(1.04);
    filter: brightness(1.05);
