---
const { current = "" } = Astro.props;
---
<header
  id="site-nav"
  class="sticky top-0 z-50 w-full bg-warm-white/90 backdrop-blur-sm border-b border-[rgba(26,23,20,0.06)] transition-shadow duration-300"
>
  <nav class="mx-auto max-w-6xl px-5 sm:px-8 lg:px-10 h-16 flex items-center justify-between">
    <a href="/" aria-label="Shunnoh — home" class="block">
      <img
        src="/images/branding/logo-wordmark-dark.svg"
        alt="Shunnoh"
        class="h-7 w-auto"
        width="210"
        height="48"
      />
    </a>

    <div class="flex items-center gap-6 sm:gap-8">
      <a
        href="/blogs"
        class={`nav-underline font-ui text-sm uppercase tracking-wider transition-colors ${current === "blogs" ? "text-ink" : "text-stone hover:text-terracotta"}`}
      >Blogs</a>

      <div class="flex items-center gap-4">
        <a href="https://www.instagram.com/shunnoh_" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-stone hover:text-terracotta transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://x.com/shunnoh_blog" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="text-stone hover:text-terracotta transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"></path>
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById("site-nav");
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 60) nav.classList.add("shadow-[0_1px_8px_rgba(26,23,20,0.04)]");
    else nav.classList.remove("shadow-[0_1px_8px_rgba(26,23,20,0.04)]");
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
