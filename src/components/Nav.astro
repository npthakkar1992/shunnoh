---
const { current = "" } = Astro.props;
---
<header
  id="site-nav"
  class="site-nav sticky top-0 z-50 w-full border-b border-[rgba(26,23,20,0.06)]"
>
    <nav class="mx-auto px-4 sm:px-6 lg:px-14 h-[72px] flex items-center justify-between" style="max-width:1360px;">
    <a href="/" aria-label="Shunnoh — home" class="block nav-logo">
      <span class="nav-wordmark">Shunnoh</span>
    </a>

    <div class="flex items-center gap-6 sm:gap-8">
      <a
        href="/blogs"
        class={`nav-underline font-ui text-sm uppercase tracking-wider hidden sm:inline ${current === "blogs" ? "text-ink" : "text-stone hover:text-terracotta"}`}
      >Blogs</a>

      <div class="flex items-center gap-4">
        <a href="https://www.instagram.com/shunnoh_" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="nav-social text-stone hover:text-terracotta">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://x.com/shunnoh_blog" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="nav-social text-stone hover:text-terracotta">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"></path>
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  .site-nav {
    background: var(--color-warm-white);
    transition: box-shadow 300ms var(--ease-soft), background-color 400ms var(--ease-soft);
  }
  .site-nav.scrolled {
    background: rgba(250, 248, 244, 0.95);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 8px rgba(26, 23, 20, 0.04);
  }
  .nav-wordmark {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 26px;
    font-weight: 400;
    color: #1a1714;
    line-height: 1;
    transition: opacity 300ms var(--ease-soft);
  }
  .nav-logo:hover .nav-wordmark { opacity: 0.8; }
  .nav-underline { transition: color 400ms var(--ease-soft); position: relative; }
  .nav-underline::after { transition: width 400ms var(--ease-soft); }
  .nav-social { display: inline-flex; transition: color 300ms var(--ease-soft), transform 300ms var(--ease-soft); }
  .nav-social:hover { transform: scale(1.08); }
</style>

<script>
  const nav = document.getElementById("site-nav");
  const onScroll = () => {
    if (!nav) return;
    nav.classList.toggle("scrolled", window.scrollY > 60);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
