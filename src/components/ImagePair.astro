---
// Renders 1+ images. Two side-by-side on desktop (stacked on mobile) is the
// common case; a single image spans full width. A shared caption sits below.
// focal (all images) or focals[i] (per image): top | center | bottom | left |
// right | custom "50% 25%" — maps to object-position for smart cropping.
const { images = [], caption = "", alt = "", focal = "center", focals = [] } = Astro.props;
const single = images.length === 1;
const focalMap = { top: "center top", center: "center", bottom: "center bottom", left: "left center", right: "right center" };
const objectPosition = (i) => {
  const f = focals[i] ?? focal;
  return focalMap[f] ?? f;
};
---
<figure class="my-10">
  <div class={single ? "" : "flex flex-wrap gap-5"}>
    {images.map((src, i) => (
      <div class={`overflow-hidden rounded bg-cream ${single ? "aspect-[3/2]" : "aspect-[4/3]"}`} style={single ? "" : "flex: 1 1 calc(50% - 0.625rem); min-width: min(280px, 100%)"}>
        <img
          src={src}
          alt={caption || alt || `Image ${i + 1}`}
          loading="lazy"
          class="img-hover h-full w-full object-cover rounded"
          style={`object-position:${objectPosition(i)};`}
        />
      </div>
    ))}
  </div>
  {caption && (
    <figcaption class="mx-auto text-center mt-3" style="font-family:var(--font-ui);font-size:0.75rem;font-style:italic;color:var(--color-stone-light);">{caption}</figcaption>
  )}
</figure>
