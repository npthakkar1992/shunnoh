---
const { note = "" } = Astro.props;
---
<footer class="bg-charcoal text-parchment mt-24">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 lg:px-10 py-16">
    <div class="grid gap-10 md:grid-cols-3 md:gap-8">
      <div class="md:col-span-1">
        <a href="/" class="font-display text-parchment" style="font-size:1.4rem;font-weight:500;letter-spacing:0.02em;">Shunnoh</a>
        <p class="font-ui text-sm text-stone mt-4 leading-relaxed max-w-xs">
          Personal tales of immersive travel, raw experiences, and unforgettable moments from my journey across destinations.
        </p>
      </div>

      <nav class="flex flex-col gap-3 md:items-center" aria-label="Footer">
        <a href="/" class="font-ui text-sm text-stone-light hover:text-parchment transition-colors w-fit">Home</a>
        <a href="/blogs" class="font-ui text-sm text-stone-light hover:text-parchment transition-colors w-fit">Blogs</a>
      </nav>

      <div class="flex gap-5 md:justify-end md:items-start">
        <a href="https://www.instagram.com/shunnoh_" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-stone hover:text-parchment transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://x.com/shunnoh_blog" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="text-stone hover:text-parchment transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"></path>
          </svg>
        </a>
      </div>
    </div>

    {note && (
      <p class="font-ui text-xs text-stone mt-12 pt-6 border-t border-[rgba(245,240,232,0.08)]">{note}</p>
    )}
  </div>
</footer>
