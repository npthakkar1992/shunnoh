---
const { note = "" } = Astro.props;
---
<footer class="site-footer mt-16 sm:mt-24 lg:mt-32" style="background:#faf8f4;">
  <div class="mx-auto px-4 sm:px-6 lg:px-14 pt-10 sm:pt-12 lg:pt-16 pb-6 sm:pb-8" style="max-width:1360px;">
    <div class="footer-grid mb-8 sm:mb-14">
      <!-- Left: wordmark + description -->
      <div class="footer-brand">
        <a href="/" aria-label="Shunnoh — home" class="block foot-logo w-fit mb-4">
          <span class="foot-wordmark">Shunnoh</span>
        </a>
        <p class="font-ui text-sm leading-relaxed max-w-xs" style="color:#8a8175;">
          Personal tales of immersive travel, raw experiences, and unforgettable moments from my journey across destinations.
        </p>
      </div>

      <!-- Right: two columns -->
      <div class="footer-links">
        <div class="footer-col">
          <p class="foot-col-label">Read</p>
          <a href="/blogs" class="foot-link nav-underline font-ui text-sm" style="color:#2d2a26;">All chapters</a>
        </div>
        <div class="footer-col">
          <p class="foot-col-label">Follow</p>
          <a href="https://www.instagram.com/shunnoh_" target="_blank" rel="noopener noreferrer" class="foot-link nav-underline font-ui text-sm" style="color:#2d2a26;">Instagram</a>
          <a href="https://x.com/shunnoh_blog" target="_blank" rel="noopener noreferrer" class="foot-link nav-underline font-ui text-sm" style="color:#2d2a26;">X / Twitter</a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom border-t" style="border-color:rgba(26,23,20,0.10);padding-top:1.25rem;">
      <p class="font-ui text-xs" style="color:#b0a89c;">© Shunnoh · MMXXVI</p>
    </div>

    {note && (
      <p class="font-ui text-xs mt-4" style="color:#8a8175;">{note}</p>
    )}
  </div>
</footer>

<style>
  .site-footer { position: relative; }
  .site-footer::before {
    content: ""; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 200px; max-width: 60%; height: 1px;
    background: linear-gradient(to right, transparent, rgba(184,112,75,0.5), transparent);
  }
  .foot-wordmark {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 28px;
    font-weight: 400;
    color: #1a1714;
    line-height: 1;
    transition: opacity 300ms var(--ease-soft);
  }
  .foot-logo:hover .foot-wordmark { opacity: 0.75; }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; gap: 28px; }
    .footer-links { justify-self: start; }
  }
  .footer-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    justify-self: end;
  }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .foot-col-label {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #b0a89c;
    margin-bottom: 4px;
  }
  .foot-link {
    transition: color 300ms var(--ease-soft);
    width: fit-content;
  }
  .foot-link:hover { color: var(--color-terracotta) !important; }
  .foot-link.nav-underline::after { background: var(--color-terracotta); transition: width 300ms ease; }
  .footer-bottom { display: flex; align-items: center; justify-content: space-between; }
</style>
